{
  "name": "scholarpro",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "cross-env NODE_ENV=dev ts-node-dev --respawn -r tsconfig-paths/register index.ts",
    "stg": "cross-env NODE_ENV=stg ts-node-dev --respawn -r tsconfig-paths/register index.ts",
    "pro": "cross-env NODE_ENV=production node -r tsconfig-paths/register index.js",
    "build": "tsc && npm run sentry:sourcemaps && tsc-alias",
    "test": "cross-env NODE_OPTIONS=--max-old-space-size=8192 jest --detectOpenHandles",
    "test:watch": "cross-env NODE_OPTIONS=--max-old-space-size=8192 jest --watch",
    "test:coverage": "cross-env NODE_OPTIONS=--max-old-space-size=8192 jest --coverage",
    "db:seed": "tsx scripts/seed/generate-mock-data.ts",
    "sentry:sourcemaps": "sentry-cli sourcemaps inject --org chea-ny --project node-express ./dist && sentry-cli sourcemaps upload --org chea-ny --project node-express ./dist"
  },
  "dependencies": {
    "@aws-sdk/client-ses": "^3.940.0",
    "@aws-sdk/client-sesv2": "^3.946.0",
    "@sentry/cli": "^2.58.4",
    "@sentry/node": "^10.32.1",
    "@sentry/profiling-node": "^10.32.1",
    "@sentry/tracing": "^7.120.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/multer": "^2.0.0",
    "axios": "^1.13.6",
    "bakong-khqr": "^1.0.20",
    "bcryptjs": "^3.0.2",
    "cookie-parser": "~1.4.4",
    "cross-env": "^10.1.0",
    "csv-parser": "^3.2.0",
    "debug": "~2.6.9",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.44.6",
    "drizzle-zod": "^0.8.3",
    "express": "^4.21.2",
    "express-rate-limit": "^8.1.0",
    "file-type": "^21.1.1",
    "html-to-text": "^9.0.5",
    "http-errors": "~1.6.3",
    "jade": "^0.29.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "pg": "^8.16.3",
    "postgres": "^3.4.7",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@faker-js/faker": "^10.2.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/dotenv": "^6.1.1",
    "@types/express": "^5.0.3",
    "@types/html-to-text": "^9.0.4",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/pg": "^8.15.5",
    "@types/uuid": "^10.0.0",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9.39.1",
    "globals": "^16.4.0",
    "jest": "^30.2.0",
    "jiti": "^2.6.1",
    "ts-jest": "^29.4.5",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.20.6",
    "typescript-eslint": "^8.46.2"
  }
}